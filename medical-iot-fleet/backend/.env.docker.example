# Copy to backend/.env.docker before running docker compose

# Required auth / app settings
SECRET_KEY=CHANGE-ME-use-a-long-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App URLs
FRONTEND_URL=https://n8nautomations.me
PUBLIC_SIGNUP_DISABLED=true
INVITE_TOKEN_EXPIRE_HOURS=72
INVITE_ACCEPT_URL=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP (optional but needed for invite email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# MQTT processing tuning
MQTT_MIN_INGEST_INTERVAL_MS=1000
MQTT_ECG_MIN_INGEST_INTERVAL_MS=120
MQTT_PROCESS_MAX_CONCURRENCY=1
MQTT_ANOMALY_ALERT_COOLDOWN_SECONDS=30
DEVICE_OFFLINE_SECONDS=5
DEVICE_PRESENCE_SWEEP_SECONDS=5

# DB pool tuning
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
